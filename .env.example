# J-Quants API key for local development (set your own key; do not commit real secrets)
JQUANTS_API_KEY=your_jquants_api_key_here

# J-Quants plan name (e.g. free, light, standard)
JQUANTS_PLAN=free

# moomoo OpenD read-only US market data integration.
# This repo does not expose moomoo trade/order APIs.
MOOMOO_OPEND_ENABLED=true
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
MOOMOO_OPEND_IS_ENCRYPT=false
MOOMOO_OPEND_MAX_HISTORY_ROWS=5000

# bt FastAPI URL used by TS clients, OpenAPI sync fallback, and Vite /api proxy
BT_API_URL=http://localhost:3002

# Optional runtime logging level for Node/Bun scripts
LOG_LEVEL=info

# Optional runtime environment label
NODE_ENV=development

# --- bt data plane (Phase 2) ---
# MARKET_TIMESERIES_BACKEND=duckdb-parquet
# MARKET_TIMESERIES_DIR=$HOME/.local/share/trading25/market-timeseries
# MARKET_TIMESERIES_SQLITE_MIRROR=true

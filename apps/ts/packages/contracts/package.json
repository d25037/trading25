{
  "name": "@trading25/contracts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types/api-types": {
      "import": "./dist/types/api-types.js",
      "types": "./dist/types/api-types.d.ts"
    },
    "./types/api-response-types": {
      "import": "./dist/types/api-response-types.js",
      "types": "./dist/types/api-response-types.d.ts"
    },
    "./types/jquants": {
      "import": "./dist/types/jquants.js",
      "types": "./dist/types/jquants.d.ts"
    },
    "./clients/backtest/generated/bt-api-types": {
      "import": "./dist/clients/backtest/generated/bt-api-types.js",
      "types": "./dist/clients/backtest/generated/bt-api-types.d.ts"
    }
  },
  "scripts": {
    "build": "bun run build:deps && bun run build:local",
    "build:deps": "bun run --filter @trading25/api-clients build",
    "build:local": "bun run bt:generate-types && tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "bun run bt:generate-types && tsc -p tsconfig.typecheck.json --noEmit",
    "bt:fetch-schema": "bun scripts/fetch-bt-openapi.ts",
    "bt:generate-types": "bunx openapi-typescript openapi/bt-openapi.json -o src/clients/backtest/generated/bt-api-types.ts",
    "bt:sync": "bun run bt:fetch-schema && bun run bt:generate-types",
    "bt:check": "bun scripts/check-bt-types.ts"
  },
  "dependencies": {
    "@trading25/api-clients": "workspace:*"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1"
  }
}

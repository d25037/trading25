{
  "name": "@trading25/utils",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./config/*": {
      "import": "./dist/config/*.js",
      "types": "./dist/config/*.d.ts"
    },
    "./errors": {
      "import": "./dist/errors/index.js",
      "types": "./dist/errors/index.d.ts"
    },
    "./errors/*": {
      "import": "./dist/errors/*.js",
      "types": "./dist/errors/*.d.ts"
    },
    "./services/auth-service": {
      "import": "./dist/services/auth-service.js",
      "types": "./dist/services/auth-service.d.ts"
    },
    "./logger-interface": {
      "import": "./dist/logger-interface.js",
      "types": "./dist/logger-interface.d.ts"
    },
    "./utils/*": {
      "import": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    },
    "./test-utils": {
      "import": "./dist/test-utils/index.js",
      "types": "./dist/test-utils/index.d.ts"
    },
    "./test-utils/*": {
      "import": "./dist/test-utils/*.js",
      "types": "./dist/test-utils/*.d.ts"
    }
  },
  "scripts": {
    "build": "bun run build:deps && bun run build:local",
    "build:deps": "bun run --filter @trading25/contracts build",
    "build:local": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@trading25/contracts": "workspace:*"
  }
}

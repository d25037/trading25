{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "..",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"],
      "@": ["./src"],
      "@trading25/api-clients": ["../api-clients/src"],
      "@trading25/api-clients/*": ["../api-clients/src/*"],
      "@trading25/contracts": ["../contracts/src"],
      "@trading25/contracts/*": ["../contracts/src/*"],
      "@trading25/utils": ["../utils/src"],
      "@trading25/utils/*": ["../utils/src/*"]
    }
  },
  "include": ["src/**/*", "../contracts/src/**/*.d.ts", "../utils/src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}

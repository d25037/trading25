{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "allowJs": true,
    "types": ["bun-types"],

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "strictNullChecks": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": false,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "baseUrl": "./",
    "paths": {
      "@trading25/api-clients": ["packages/api-clients/src"],
      "@trading25/api-clients/*": ["packages/api-clients/src/*"],
      "@trading25/contracts": ["packages/contracts/src"],
      "@trading25/contracts/*": ["packages/contracts/src/*"],
      "@trading25/domain": ["packages/domain/src"],
      "@trading25/domain/*": ["packages/domain/src/*"],
      "@trading25/utils": ["packages/utils/src"],
      "@trading25/utils/*": ["packages/utils/src/*"],
      "@trading25/web": ["packages/web/src"]
    }
  },
  "include": [
    "packages/contracts/src/**/*",
    "packages/domain/src/**/*",
    "packages/utils/src/**/*",
    "node_modules/bun-types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "**/dist", "**/*.disabled/**", "**/examples.disabled/**"]
}
